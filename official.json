      ],
      "types": [
        "flashcard",
        "mcq-single",
        "mcq-multi",
        "true-false",
        "match-pairs",
        "sort-items",
        "short-answer",
        "note"
      ],
      "features": [
        "markdown",
        "math",
        "html"
      ],
      "assets": { "image": ["*"], "audio": ["*"], "video": ["*"], "model": null }
    },
    "appSpecific": {
      "memizy": {
        "pluginSdk": {
          "apiVersion": "0.3",
          "minimumHostApiVersion": "0.3"
        },
        "registry": {
          "isStandaloneFile": true
        }
      }
    }
  },
